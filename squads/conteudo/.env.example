# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Squad Conteudo — Configuracao de APIs
# Execute *setup-publicacao para configurar
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Instagram Graph API (publicar direto)
# Obter em: https://developers.facebook.com/docs/instagram-api/
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_BUSINESS_ACCOUNT_ID=
INSTAGRAM_TOKEN_CREATED_AT=

# Hosting de imagens (necessario para publicar)
# Obter em: https://api.imgbb.com/
IMGBB_API_KEY=

# Blotato MCP (multi-plataforma: IG + LinkedIn + X + TikTok + YouTube)
# Obter em: https://blotato.com → Settings → API
BLOTATO_API_KEY=

# Geracao de Imagens IA
# Gemini (gratis ate 500/dia): https://aistudio.google.com/apikey
GEMINI_API_KEY=
# OpenRouter (pay-per-use): https://openrouter.ai/
OPENROUTER_API_KEY=
