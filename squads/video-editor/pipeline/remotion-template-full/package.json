{
  "name": "video-editor-remotion-template-full",
  "version": "0.1.0",
  "private": true,
  "description": "Remotion template: full-video edit mode (video + captions + optional image overlay)",
  "scripts": {
    "start": "remotion studio",
    "build": "remotion render src/index.ts FullEdit out/full-edit.mp4",
    "render": "remotion render src/index.ts FullEdit out/full-edit.mp4 --codec=h264"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "remotion": "^4.0.0",
    "@remotion/cli": "^4.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "typescript": "^5.4.0"
  }
}
