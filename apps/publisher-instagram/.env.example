# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Pipeline de Publicação Instagram — Castelo Forte
# Copie para .env (mesmo diretório) e preencha
# Tokens reais entregues pelo administrador via canal seguro
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# ─── Instagram Graph API ───
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_BUSINESS_ACCOUNT_ID=
FACEBOOK_PAGE_ID=
GRAPH_API_VERSION=v21.0

# ─── Supabase Storage (hosting de PNGs publicados) ───
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
SUPABASE_BUCKET=carrossel-images
SUPABASE_FOLDER=instagram-posts
